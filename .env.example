# UniFi Access Open API token (create in Access -> Settings -> API Token).
# Used as: Authorization: Bearer $UNIFI_API_KEY against https://<console>:12445
UNIFI_API_KEY=

# Controller used by the Rust admin CLI and gateway service.
UNIFI_ACCESS_HOST=https://100.89.168.42:12445

# Entry Gate used by visitor enrollment and the RFID gate service.
UNIFI_ENTRY_GATE_DOOR_ID=1b620b81-f457-45f7-9fd2-27de1d8c4fdc

# The controller currently uses a self-signed certificate.
UNIFI_TLS_VERIFY=false
