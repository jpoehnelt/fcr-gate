# Non-secret gateway service configuration. Store the real file under
# /data/fcr-gate/secrets/gateway.env with mode 0600.

IMPINJ_HOST=https://192.168.10.229
IMPINJ_USERNAME=root
IMPINJ_PASSWORD_FILE=/data/fcr-gate/secrets/impinj-password
IMPINJ_TLS_VERIFY=false
IMPINJ_PROFILE_ID=fcr-gate-encoder
IMPINJ_ANTENNA_PORT=1
IMPINJ_TX_POWER_CDBM=3000
IMPINJ_RF_MODE=4

# Observe candidates first. Set a site-unique 64-bit prefix before enabling writes;
# the service appends a durable 32-bit sequence to produce a 96-bit EPC.
RFID_WRITES_ENABLED=false
RFID_DEFAULT_EPC=300833B2DDD9014000000000
RFID_EPC_PREFIX=
RFID_MIN_RSSI_CDBM=-5000
RFID_CONFIRM_READS=5
RFID_CONFIRM_WINDOW_MS=1500
RFID_ACCESS_TIMEOUT_MS=15000
RFID_RETRY_COOLDOWN_MS=3000
RFID_MAX_ATTEMPTS=3
RFID_STATE_DB=/data/fcr-gate/rfid-encoder.sqlite3
RFID_ENCODER_ACTOR=gate-auto

# Operator assignment UI. Keep the bind address on loopback and put the hostname
# behind Cloudflare Tunnel + Access before enabling it.
FCR_GATE_WEB_ENABLED=false
FCR_GATE_WEB_BIND=127.0.0.1
FCR_GATE_WEB_PORT=8080
RFID_CLAIM_WINDOW_MS=60000

# Minimal process/reader/database health endpoint at /healthz. This remains
# available when the operator UI is disabled and contains no tag or user data.
FCR_GATE_HEALTH_ENABLED=true
FCR_GATE_HEALTH_STALE_MS=120000

# UniFi Access is the source of truth for users, Entry Gate policies, and schedules.
# The API token needs view:user, view:policy, view:space, and edit:space.
UNIFI_ACCESS_HOST=https://100.89.168.42:12445
UNIFI_API_KEY_FILE=/data/fcr-gate/secrets/unifi-access-api-key
UNIFI_TLS_VERIFY=false
UNIFI_ENTRY_GATE_DOOR_ID=1b620b81-f457-45f7-9fd2-27de1d8c4fdc

# Gate authorization is independent from encoding and the UI. Use dry-run to run
# and audit every UniFi check without sending a door-unlock command.
RFID_GATE_MODE=disabled
RFID_GATE_UNLOCK_COOLDOWN_MS=30000

# UniFi weekly schedules are evaluated in the process's local timezone.
TZ=America/Denver
